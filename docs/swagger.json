                                "type": "string"
                            }
                        }
                    }
                }
            }
        },
        "/api/weather/sync": {
            "post": {
                "description": "Mengambil data cuaca dari API BMKG berdasarkan kode wilayah (adm4) dan menyimpannya ke database",
                "tags": [
                    "Weather"
                ],
                "summary": "Sinkronisasi Data BMKG",
                "parameters": [
                    {
                        "type": "string",
                        "description": "Kode Wilayah (contoh: 31.71.01.1001)",
                        "name": "adm4",
                        "in": "query",
                        "required": true
                    }
                ],
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "type": "object",
                            "additionalProperties": {
                                "type": "string"
                            }
                        }
                    },
                    "400": {
                        "description": "Bad Request",
                        "schema": {
                            "type": "object",
                            "additionalProperties": {
                                "type": "string"
                            }
                        }
                    },
                    "500": {
                        "description": "Internal Server Error",
                        "schema": {
                            "type": "object",
                            "additionalProperties": {
                                "type": "string"
                            }
                        }
                    }
                }
            }
        },
        "/api/weather/update": {
            "put": {
                "consumes": [
                    "application/json"
                ],
                "tags": [
                    "Weather"
                ],
                "summary": "Update Data Cuaca",
                "parameters": [
                    {
                        "type": "string",
                        "description": "ID Weather",
                        "name": "id",
                        "in": "query",
                        "required": true
                    },
                    {
                        "description": "Data Weather",
                        "name": "weather",
                        "in": "body",
                        "required": true,
                        "schema": {
                            "$ref": "#/definitions/models.Weather"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "type": "object",
                            "additionalProperties": {
                                "type": "string"
                            }
                        }
                    }
                }
            }
        },
        "/health": {
            "get": {
                "description": "Endpoint untuk memastikan backend berjalan lancar",
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "System"
                ],
                "summary": "Cek Status Server",
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "type": "object",
                            "additionalProperties": {
                                "type": "string"
                            }
                        }
                    }
                }
            }
        }
    },
