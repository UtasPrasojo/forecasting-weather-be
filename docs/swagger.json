{
    "swagger": "2.0",
    "info": {
        "description": "Backend service untuk konsumsi API dan Dashboard Analitik.",
        "title": "API Analitik Publik",
        "contact": {},
        "version": "1.0"
    },
    "host": "localhost:8080",
    "basePath": "/",
    "paths": {
        "/api/activity": {
            "get": {
                "description": "Mengambil semua daftar kegiatan dengan fitur pencarian dan pengurutan",
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "Activity"
                ],
                "summary": "Daftar Semua Kegiatan",
                "parameters": [
                    {
                        "type": "string",
                        "description": "Cari berdasarkan nama atau status cuaca",
                        "name": "search",
                        "in": "query"
                    },
                    {
                        "type": "string",
                        "description": "Kolom pengurutan (contoh: activity_date, name)",
                        "name": "sort_by",
                        "in": "query"
                    },
                    {
                        "type": "string",
                        "description": "Urutan data (asc/desc)",
                        "name": "order",
                        "in": "query"
                    }
                ],
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "type": "array",
                            "items": {
                                "$ref": "#/definitions/models.Activity"
                            }
                        }
                    },
                    "500": {
                        "description": "Internal Server Error",
                        "schema": {
                            "type": "object",
                            "additionalProperties": {
                                "type": "string"
                            }
                        }
                    }
                }
            },
            "post": {
                "description": "Membuat rencana kegiatan baru dan otomatis mencocokkan status cuaca berdasarkan data BMKG yang tersedia",
                "consumes": [
                    "application/json"
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "Activity"
                ],
                "summary": "Buat Rencana Kegiatan",
                "parameters": [
                    {
                        "description": "Data JSON Kegiatan",
                        "name": "activity",
                        "in": "body",
                        "required": true,
                        "schema": {
                            "$ref": "#/definitions/models.Activity"
                        }
                    }
                ],
                "responses": {
                    "201": {
                        "description": "Created",
                        "schema": {
                            "$ref": "#/definitions/models.Activity"
                        }
                    },
                    "400": {
                        "description": "Bad Request",
                        "schema": {
                            "type": "object",
                            "additionalProperties": {
                                "type": "string"
                            }
                        }
                    }
                }
            }
        },
        "/api/activity/delete": {
            "delete": {
                "description": "Menghapus data kegiatan berdasarkan ID",
                "tags": [
                    "Activity"
                ],
                "summary": "Hapus Kegiatan",
                "parameters": [
                    {
                        "type": "string",
                        "description": "ID Kegiatan",
                        "name": "id",
                        "in": "query",
                        "required": true
                    }
                ],
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "type": "object",
                            "additionalProperties": {
                                "type": "string"
                            }
                        }
                    }
                }
            }
        },
        "/api/activity/update": {
            "put": {
                "description": "Mengubah data kegiatan dan memperbarui status cuaca secara otomatis",
                "consumes": [
                    "application/json"
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "Activity"
                ],
                "summary": "Perbarui Kegiatan",
                "parameters": [
                    {
                        "type": "string",
                        "description": "ID Kegiatan yang akan diubah",
                        "name": "id",
                        "in": "query",
                        "required": true
                    },
                    {
                        "description": "Data JSON Kegiatan baru",
                        "name": "activity",
                        "in": "body",
                        "required": true,
                        "schema": {
                            "$ref": "#/definitions/models.Activity"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "$ref": "#/definitions/models.Activity"
                        }
                    },
                    "400": {
                        "description": "Bad Request",
                        "schema": {
                            "type": "object",
                            "additionalProperties": {
                                "type": "string"
                            }
                        }
                    },
                    "404": {
                        "description": "Not Found",
                        "schema": {
                            "type": "object",
                            "additionalProperties": {
                                "type": "string"
                            }
                        }
                    }
                }
            }
        },
        "/api/weather": {
            "get": {
                "description": "Mengambil semua data cuaca yang telah di-sync, diurutkan berdasarkan waktu sinkronisasi terbaru",
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "Weather"
                ],
                "summary": "Daftar Semua Data Cuaca",
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "type": "array",
                            "items": {
                                "$ref": "#/definitions/models.Weather"
                            }
                        }
                    },
                    "500": {
                        "description": "Internal Server Error",
                        "schema": {
                            "type": "object",
                            "additionalProperties": {
                                "type": "string"
                            }
                        }
                    }
                }
            }
        },
        "/api/weather/dashboard": {
            "get": {
                "description": "Mengambil data agregasi untuk Pie Chart (Kategori) dan Column Chart (Suhu Harian)",
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "Dashboard"
                ],
                "summary": "Data Statistik Dashboard",
                "responses": {
                    "200": {
                        "description": "Contoh: {pie_chart: [], column_chart: []}",
                        "schema": {
                            "type": "object",
                            "additionalProperties": true
                        }
                    }
                }
            }
        },
        "/api/weather/delete": {
            "delete": {
                "tags": [
                    "Weather"
                ],
                "summary": "Hapus Data Cuaca",
                "parameters": [
                    {
                        "type": "string",
                        "description": "ID Weather",
                        "name": "id",
                        "in": "query",
                        "required": true
                    }
                ],
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "type": "object",
                            "additionalProperties": {
                                "type": "string"
                            }
                        }
                    }
                }
            }
        },
        "/api/weather/detail": {
            "get": {
                "tags": [
                    "Weather"
                ],
                "summary": "Detail Data Cuaca",
                "parameters": [
                    {
                        "type": "string",
                        "description": "ID Weather",
                        "name": "id",
                        "in": "query",
                        "required": true
                    }
                ],
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "type": "object",
